        <!-- ================= SECTION 3: แบบจำลองฟิสิกส์ 2 มิติ (Physics Simulation) ================= -->
        <section class="bg-white p-8 rounded-2xl shadow-md border border-slate-100">
            <h2 class="text-2xl font-bold mb-6 text-slate-800">
