                            <td class="p-4">789</td>
                            <td class="p-4">1.2 × 10⁻³</td>
                        </tr>
                        <tr class="border-b border-slate-100 hover:bg-slate-50 transition">
                            <td class="p-4 font-medium"><span class="show-en">Water</span><span class="show-th">น้ำ (Water)</span></td>
                            <td class="p-4">1000</td>
                            <td class="p-4">1.0 × 10⁻³</td>
                        </tr>
                        <tr class="border-b border-slate-100 hover:bg-slate-50 transition">
                            <td class="p-4 font-medium"><span class="show-en">Motor Oil (SAE 30)</span><span class="show-th">น้ำมันเครื่อง (Motor Oil)</span></td>
                            <td class="p-4">880</td>
                            <td class="p-4">0.2</td>
                        </tr>
                        <tr class="border-b border-slate-100 hover:bg-slate-50 transition">
                            <td class="p-4 font-medium"><span class="show-en">Castor Oil</span><span class="show-th">น้ำมันละหุ่ง (Castor Oil)</span></td>
                            <td class="p-4">961</td>
                            <td class="p-4">0.985</td>
                        </tr>
                        <tr class="border-b border-slate-100 hover:bg-slate-50 transition">
                            <td class="p-4 font-medium"><span class="show-en">Corn Syrup</span><span class="show-th">น้ำเชื่อมข้าวโพด (Corn Syrup)</span></td>
                            <td class="p-4">1380</td>
                            <td class="p-4">1.38</td>
                        </tr>
                        <tr class="border-b border-slate-100 hover:bg-slate-50 transition">
                            <td class="p-4 font-medium"><span class="show-en">Glycerin</span><span class="show-th">กลีเซอรีน (Glycerin)</span></td>
                            <td class="p-4">1260</td>
                            <td class="p-4">1.4</td>
                        </tr>
                        <tr class="border-b border-slate-100 hover:bg-slate-50 transition">
