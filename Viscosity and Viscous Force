        .lang-toggle-container[data-lang="th"] .text-th { color: #f97316; }

        /* =========================================
           ระบบซ่อน/แสดงข้อความตามภาษา (Bilingual Display)
           ควบคุมผ่านคลาส 'lang-th' หรือ 'lang-en' ที่แท็ก <body>
           ========================================= */
        .show-th { display: none; } /* ซ่อนภาษาไทยเป็นค่าเริ่มต้น (เพราะแสดง ENG) */
