    <!-- ================= JAVASCRIPT LOGIC ================= -->
    <script>
        // ---------------------------------------------------------
        // 1. Data Definitions (ฐานข้อมูลคุณสมบัติของของไหลและวัตถุ)
        // ---------------------------------------------------------
        const dropdownData = {
            fluids: [
                { id: 'air', en: 'Air (η=1.8e-5, ρ=1.2)', th: 'อากาศ (η=1.8e-5, ρ=1.2)' },
                { id: 'ethanol', en: 'Ethanol (η=0.0012, ρ=789)', th: 'เอทานอล (η=0.0012, ρ=789)' },
                { id: 'water', en: 'Water (η=0.001, ρ=1000)', th: 'น้ำ (η=0.001, ρ=1000)' },
                { id: 'motor_oil', en: 'Motor Oil (η=0.2, ρ=880)', th: 'น้ำมันเครื่อง (η=0.2, ρ=880)' },
                { id: 'castor_oil', en: 'Castor Oil (η=0.985, ρ=961)', th: 'น้ำมันละหุ่ง (η=0.985, ρ=961)' },
                { id: 'corn_syrup', en: 'Corn Syrup (η=1.38, ρ=1380)', th: 'น้ำเชื่อมข้าวโพด (η=1.38, ρ=1380)' },
                { id: 'glycerin', en: 'Glycerin (η=1.4, ρ=1260)', th: 'กลีเซอรีน (η=1.4, ρ=1260)' },
                { id: 'honey', en: 'Honey (η=10.0, ρ=1420)', th: 'น้ำผึ้ง (η=10.0, ρ=1420)' },
                { id: 'custom', en: 'Custom / Manual Input', th: 'กำหนดค่าเอง (พิมพ์ตัวเลขด้านล่าง)' }
            ],
            materials: [
                { id: 'steel', en: 'Steel Ball (ρ=7800)', th: 'ลูกเหล็ก (ρ=7800)' },
                { id: 'glass', en: 'Glass Marble (ρ=2500)', th: 'ลูกแก้ว (ρ=2500)' },
                { id: 'wood', en: 'Wood Ball (Floats, ρ=700)', th: 'ลูกไม้ (ลอยน้ำ, ρ=700)' }
            ]
        };

        const physicsData = {
            fluids: {
                air: { rho: 1.2, eta: 0.000018 },
                ethanol: { rho: 789, eta: 0.0012 },
                water: { rho: 1000, eta: 0.001 },
                motor_oil: { rho: 880, eta: 0.2 },
                castor_oil: { rho: 961, eta: 0.985 },
                corn_syrup: { rho: 1380, eta: 1.38 },
                glycerin: { rho: 1260, eta: 1.4 },
                honey: { rho: 1420, eta: 10.0 }
            },
            materials: {
                steel: { rho: 7800 },
                glass: { rho: 2500 },
                wood: { rho: 700 }
            }
        };

        // ---------------------------------------------------------
        // 2. Language Toggle Logic (ฟังก์ชันเปลี่ยนภาษา)
        // ---------------------------------------------------------
        function updateDropdownTexts(lang) {
            const fluidSelect = document.getElementById('fluidType');
            const matSelect = document.getElementById('objMaterial');
            
            const fVal = fluidSelect.value;
            const mVal = matSelect.value;

            fluidSelect.innerHTML = dropdownData.fluids.map(f => 
                `<option value="${f.id}">${lang === 'th' ? f.th : f.en}</option>`
            ).join('');
            
            matSelect.innerHTML = dropdownData.materials.map(m => 
                `<option value="${m.id}">${lang === 'th' ? m.th : m.en}</option>`
            ).join('');

            if(fVal) fluidSelect.value = fVal;
            if(mVal) matSelect.value = mVal;
        }

        function toggleLanguage() {
            const body = document.body;
            const toggleContainer = document.getElementById('langToggle');
            let currentLang = 'en';
            
            if (body.classList.contains('lang-en')) {
                body.classList.remove('lang-en');
                body.classList.add('lang-th');
                toggleContainer.setAttribute('data-lang', 'th');
                currentLang = 'th';
            } else {
                body.classList.remove('lang-th');
                body.classList.add('lang-en');
                toggleContainer.setAttribute('data-lang', 'en');
                currentLang = 'en';
            }
            
            updateDropdownTexts(currentLang);
            solveEx1();
            solveEx2();
            updateChartLabels();
            previewPosition(); // เรียกใหม่เพื่อให้ข้อความในกล่องแจ้งเตือนถูกแปล
        }

        // ---------------------------------------------------------
        // 3. Interactive Examples Logic (โจทย์คำนวณ)
        // ---------------------------------------------------------
        function formatSci(num) {
            return num.toExponential(3).replace('e', ' \\times 10^{').replace('+', '') + '}';
        }

        function solveEx1() {
            const isTh = document.body.classList.contains('lang-th');
            const r_mm = parseFloat(document.getElementById('ex1_r').value);
            const rho_s = parseFloat(document.getElementById('ex1_rhos').value);
            const rho_f = parseFloat(document.getElementById('ex1_rhof').value);
            const eta = parseFloat(document.getElementById('ex1_eta').value);
            const g = 9.8;

            if (isNaN(r_mm) || isNaN(rho_s) || isNaN(rho_f) || isNaN(eta)) return;

            const r = r_mm / 1000;
            const vt = (2/9) * ((rho_s - rho_f) * g * (r*r)) / eta;

            const html = `
                <div class="space-y-4">
                    <p class="font-semibold text-slate-700">${isTh ? 'วิธีทำ:' : 'Solution:'}</p>
                    <div class="text-center">$$ v_t = \\frac{2}{9} \\frac{r^2 g (\\rho_s - \\rho_f)}{\\eta} $$</div>
                    <ul class="list-disc pl-8 mb-4 text-slate-600">
                        <li>\\( r = ${r_mm} \\times 10^{-3} \\) m</li>
                        <li>\\( \\rho_s = ${rho_s} \\) kg/m³ , \\( \\rho_f = ${rho_f} \\) kg/m³</li>
                        <li>\\( \\eta = ${eta} \\) Pa·s</li>
                    </ul>
                    <div class="text-center overflow-x-auto">
                        $$ v_t = \\frac{2}{9} \\frac{(${r_mm} \\times 10^{-3})^2 (9.8) (${rho_s} - ${rho_f})}{${eta}} $$
                    </div>
                    <div class="text-center font-bold text-blue-700 text-xl mt-4">
                        $$ v_t = ${vt.toFixed(4)} \\text{ m/s} $$
                    </div>
                </div>
            `;
            document.getElementById('solution1').innerHTML = html;
            if(window.MathJax && window.MathJax.typesetPromise) {
                MathJax.typesetPromise([document.getElementById('solution1')]);
            }
        }

        function solveEx2() {
            const isTh = document.body.classList.contains('lang-th');
            const r_mm = parseFloat(document.getElementById('ex2_r').value);
            const eta_base = parseFloat(document.getElementById('ex2_eta').value);
            const v = parseFloat(document.getElementById('ex2_v').value);

            if (isNaN(r_mm) || isNaN(eta_base) || isNaN(v)) return;

            const r = r_mm / 1000;
            const eta = eta_base * 1e-5;
            const fd = 6 * Math.PI * eta * r * v;

            const html = `
                <div class="space-y-4">
                    <p class="font-semibold text-slate-700">${isTh ? 'วิธีทำ:' : 'Solution:'}</p>
                    <div class="text-center">$$ F_d = 6 \\pi \\eta r v $$</div>
                    <ul class="list-disc pl-8 mb-4 text-slate-600">
                        <li>\\( r = ${r_mm} \\times 10^{-3} \\) m</li>
                        <li>\\( \\eta = ${eta_base} \\times 10^{-5} \\) Pa·s</li>
                        <li>\\( v = ${v} \\) m/s</li>
                    </ul>
                    <div class="text-center overflow-x-auto">
                        $$ F_d = 6 \\pi (${eta_base} \\times 10^{-5})(${r_mm} \\times 10^{-3})(${v}) $$
                    </div>
                    <div class="text-center font-bold text-emerald-700 text-xl mt-4">
                        $$ F_d = ${formatSci(fd)} \\text{ N} $$
                    </div>
                </div>
            `;
            document.getElementById('solution2').innerHTML = html;
            if(window.MathJax && window.MathJax.typesetPromise) {
                MathJax.typesetPromise([document.getElementById('solution2')]);
            }
        }

        // ---------------------------------------------------------
        // 4. Core Physics Simulation Logic (ระบบจำลองฟิสิกส์ 2 มิติ)
        // ---------------------------------------------------------
        let canvas, ctx, myChart;
        let simRunning = false;
        let animationId;
        
        let params = { rho_s: 7800, rho_f: 1260, eta: 1.4, r_m: 0.01 }; 
        let state = { y_m: 0, v: 0, time: 0 };
        const g = 9.8;
        
        let tankHeight_m = 5.0; 
        let pixelsPerMeter = 100; 
        let forceScale = 1; 
        
        let markers = [];
        let nextMarkerTime = 0.2;
        let markerInterval = 0.2; // ระบบปรับระยะ marker อัตโนมัติ

        let simMaxTime = 1.0; 
        let simSpeedMultiplier = 1.0; // ตัวคูณเร่ง/ลดเวลา เพื่อไม่ให้ผู้เล่นรอนานไป

        function initSim() {
            // สร้าง Dropdown ทันทีเมื่อโหลด เพื่อป้องกันบั๊กการตั้งค่าผิดพลาด
            updateDropdownTexts(document.body.classList.contains('lang-th') ? 'th' : 'en');

            document.getElementById('fluidType').value = 'glycerin';
            document.getElementById('objMaterial').value = 'steel';
            
            document.getElementById('customFluidRho').value = physicsData.fluids['glycerin'].rho;
            document.getElementById('customFluidEta').value = physicsData.fluids['glycerin'].eta;
            
            canvas = document.getElementById('simCanvas');
            ctx = canvas.getContext('2d');
            
            const topPadding = 20;
            const bottomPadding = 20;
            const availableHeight = canvas.height - topPadding - bottomPadding;
            pixelsPerMeter = availableHeight / tankHeight_m;
            
            const ctxChart = document.getElementById('velChart').getContext('2d');
            myChart = new Chart(ctxChart, {
                type: 'line',
                data: { datasets: [{ label: 'Velocity', data: [], borderColor: 'rgb(37, 99, 235)', backgroundColor: 'rgba(37, 99, 235, 0.1)', borderWidth: 2, fill: true, pointRadius: 0, tension: 0.1 }] },
                options: {
                    responsive: true, maintainAspectRatio: false, animation: false,
                    scales: {
                        // ปรับให้กราฟเป็นประเภทแกน Linear เพื่อความแม่นยำทางคณิตศาสตร์ 100%
                        x: { type: 'linear', min: 0, title: { display: true, text: 'Time (s)' } },
                        y: { title: { display: true, text: 'Velocity (m/s)' } }
                    },
                    plugins: { legend: { display: false }, tooltip: { enabled: false } }
                }
            });

            updateSimParams();
            setTimeout(() => { solveEx1(); solveEx2(); }, 800);
        }

        function onFluidSelectChange() {
            const fType = document.getElementById('fluidType').value;
            if (fType !== 'custom' && physicsData.fluids[fType]) {
                document.getElementById('customFluidRho').value = physicsData.fluids[fType].rho;
                document.getElementById('customFluidEta').value = physicsData.fluids[fType].eta;
            }
            updateSimParams();
        }

        function onCustomFluidInput() {
            document.getElementById('fluidType').value = 'custom';
            updateSimParams();
        }

        function updateChartLabels() {
            if(!myChart) return;
            const isTh = document.body.classList.contains('lang-th');
            myChart.options.scales.x.title.text = isTh ? 'เวลา (s)' : 'Time (s)';
            myChart.options.scales.y.title.text = isTh ? 'ความเร็ว (m/s)' : 'Velocity (m/s)';
            myChart.update();
        }

        function updateSimParams() {
            const mType = document.getElementById('objMaterial').value || 'steel';
            const r_mm = parseFloat(document.getElementById('objRadius').value);
            
            params.rho_f = parseFloat(document.getElementById('customFluidRho').value) || 1000;
            params.eta = parseFloat(document.getElementById('customFluidEta').value) || 0.001;
            
            // ป้องกันไม่ให้ค่าความหนืดเป็นศูนย์หรือติดลบ 
            if (params.eta <= 0) params.eta = 0.00001; 

            params.rho_s = physicsData.materials[mType].rho;
            params.r_m = r_mm / 1000;
            
            document.getElementById('radiusVal').innerText = r_mm + " mm";
            
            const vol = (4/3) * Math.PI * Math.pow(params.r_m, 3);
            const maxW = vol * Math.max(7800, params.rho_s) * g; 
            forceScale = (canvas.height / 5) / maxW; 

            previewPosition();
        }

        function updateTubeHeight() {
            tankHeight_m = parseFloat(document.getElementById('tubeHeight').value);
            document.getElementById('tubeHeightVal').innerText = tankHeight_m.toFixed(1) + " m";
            
            const startHeightInput = document.getElementById('startHeight');
            startHeightInput.max = Math.max(0, tankHeight_m - 0.5).toString(); 
            if (parseFloat(startHeightInput.value) > tankHeight_m) {
                startHeightInput.value = Math.max(0, tankHeight_m - 0.5).toString();
            }
            
            const topPadding = 20;
            const bottomPadding = 20;
            const availableHeight = canvas.height - topPadding - bottomPadding;
            pixelsPerMeter = availableHeight / tankHeight_m;
            
            previewPosition();
        }

        // ฟังก์ชันหัวใจสำคัญ! จำลองการตกแบบล่วงหน้าเงียบๆ เพื่อหาขอบเขตกราฟ ป้องกันแกนสเกลเด้งไปมา
        function precalcSimulation() {
            let sim_y = parseFloat(document.getElementById('startHeight').value);
            let sim_v = 0;
            let sim_t = 0;
            const DT = 0.01;
            
            const vol = (4/3) * Math.PI * Math.pow(params.r_m, 3);
            const m = vol * params.rho_s;
            const W = m * g;
            const Fb = vol * params.rho_f * g;
            
            let min_v = 0;
            let max_v = 0;
            let iterations = 0;
            
            // จำกัดจำนวนลูปกันค้าง เผื่อผู้ใช้ตั้งค่าแปลกๆ แล้ววัตถุแทบไม่ขยับ
            while (iterations < 100000) { 
                const Fd_mag = 6 * Math.PI * params.eta * params.r_m * Math.abs(sim_v);
                const dir = sim_v >= 0 ? 1 : -1; 
                const Fnet = W - Fb - (Fd_mag * dir);
                const a = Fnet / m;
                
                sim_v += a * DT;
                sim_y += sim_v * DT;
                sim_t += DT;
                
                if (sim_v > max_v) max_v = sim_v;
                if (sim_v < min_v) min_v = sim_v;
                
                // สิ้นสุดเมื่อชนพื้น หรือพ้นผิวน้ำ(กรณีลอย)
                if (sim_y >= tankHeight_m && sim_v > 0) break;
                if (sim_y <= 0 && sim_v < 0) break;
                
                // ออกจากลูปถ้านิ่งสนิทจริงๆ
                if (Math.abs(a) < 1e-6 && Math.abs(sim_v) < 1e-6) break;
                
                iterations++;
            }
            
            return { max_t: Math.max(0.1, sim_t), max_v: max_v, min_v: min_v };
        }

        // ตั้งค่ากราฟและเตรียมพร้อมสำหรับการรันแอนิเมชัน
        function previewPosition() {
            simRunning = false;
            if (animationId) cancelAnimationFrame(animationId);
            
            const startM = parseFloat(document.getElementById('startHeight').value);
            document.getElementById('startHeightVal').innerText = startM.toFixed(1) + " m";
            state.y_m = startM;
            state.v = 0;
            state.time = 0;
            markers = [];
            
            // คำนวณความเร็วและเวลาสูงสุดที่วัตถุจะใช้เดินทางถึงพื้น
            const bounds = precalcSimulation();
            simMaxTime = bounds.max_t;
            
            // 1. ระบบลดระยะเวลาการรอของผู้เรียนให้เหลือประมาณ 3-4 วินาที 
            // ถ้าน้ำผึ้งตก 100 วินาที จะถูกเร่งสปีดให้แสดงผลจบในเวลาไม่นาน
            simSpeedMultiplier = simMaxTime / 4.0;
            if (simSpeedMultiplier < 0.1) simSpeedMultiplier = 0.1; 
            if (simSpeedMultiplier > 1000) simSpeedMultiplier = 1000;
            
            // 2. ระบบป้องกันจุดบนหน้าจอเยอะเกินไป (ปรับระยะการมาร์กจุดตามเวลาที่ใช้ตกทั้งหมด)
            if (simMaxTime <= 1) markerInterval = 0.1;
            else if (simMaxTime <= 2) markerInterval = 0.2;
            else if (simMaxTime <= 5) markerInterval = 0.5;
            else if (simMaxTime <= 10) markerInterval = 1.0;
            else if (simMaxTime <= 20) markerInterval = 2.0;
            else if (simMaxTime <= 50) markerInterval = 5.0;
            else if (simMaxTime <= 100) markerInterval = 10.0;
            else markerInterval = 20.0;
            
            nextMarkerTime = markerInterval;
            
            // รีเซ็ตกราฟให้เป็น 0 เสมอ
            chartData = [{ x: 0, y: 0 }];
            lastChartTime = 0;
            physicsAccumulator = 0;
            
            if (myChart) {
                myChart.data.datasets[0].data = chartData;
                myChart.options.scales.x.min = 0;
                myChart.options.scales.x.max = simMaxTime * 1.05; // เผื่อขอบแกน X นิดหน่อย
                
                const padMax = bounds.max_v * 1.1;
                const padMin = bounds.min_v * 1.1;

                // ล็อกแกน Y ให้คงที่ตลอดการรันแอนิเมชัน ไม่กระตุกหรือบีบสเกลหนีเส้นกราฟ!
                if (bounds.min_v < -0.001 && bounds.max_v <= 0.001) { 
                    myChart.options.scales.y.min = padMin;
                    myChart.options.scales.y.max = 0;
                } else if (bounds.max_v > 0.001 && bounds.min_v >= -0.001) { 
                    myChart.options.scales.y.min = 0;
                    myChart.options.scales.y.max = padMax;
                } else { 
                    myChart.options.scales.y.min = padMin - 0.1;
                    myChart.options.scales.y.max = padMax + 0.1;
                }
                
                myChart.update();
            }

            // คำนวณความเร็วปลายเชิงทฤษฎีและประเมินผลลัพธ์
            const vt = (2/9) * (params.rho_s - params.rho_f) * g * Math.pow(params.r_m, 2) / params.eta;
            const isTh = document.body.classList.contains('lang-th');
            const msgEl = document.getElementById('terminalVelocityDisplay');
            
            // หาความเร็วสูงสุดที่ทำได้ในท่อความสูงที่ตั้งไว้ 
            const simMaxSpeed = Math.max(Math.abs(bounds.max_v), Math.abs(bounds.min_v));
            
            // ถ้าตกลงมาจนถึง 95% ของความเร็วปลาย แสดงว่ากราฟโค้งเป็นความเร็วปลายแล้ว
            if (simMaxSpeed >= Math.abs(vt) * 0.95) {
                msgEl.innerText = isTh ? `ความเร็วปลายทฤษฎี (vt) = ${vt.toFixed(4)} m/s` : `Theoretical Terminal Velocity (vt) = ${vt.toFixed(4)} m/s`;
                msgEl.className = "text-center text-sm font-bold text-blue-600 mt-2 min-h-[40px] flex items-center justify-center";
            } else {
            // ถ้าน้อยกว่า แสดงว่าของเหลวความหนืดต่ำไป หรือท่อสั้นไป (ชนพื้นก่อน) กราฟจะเป็นเกือบเส้นตรง ให้แจ้งเตือนนักเรียน!
                msgEl.innerText = isTh ? `(ท่อสั้นเกินไป วัตถุตกถึงพื้นก่อนจะถึงความเร็วปลายทฤษฎีที่ ${vt.toExponential(2)} m/s)` 
                                       : `(Tube too short: hits bottom before reaching theoretical vt of ${vt.toExponential(2)} m/s)`;
                msgEl.className = "text-center text-sm font-bold text-orange-500 mt-2 min-h-[40px] flex items-center justify-center";
            }

            drawFrame();
        }

        function drawArrow(fromX, fromY, length, color, isUp) {
            if (Math.abs(length) < 2) return; 
            const toY = isUp ? fromY - length : fromY + length;
            const headlen = Math.min(8, Math.abs(length) * 0.5); 
            const dir = isUp ? -1 : 1;
            
            ctx.beginPath();
            ctx.moveTo(fromX, fromY);
            ctx.lineTo(fromX, toY);
            ctx.lineTo(fromX - headlen*0.6, toY - headlen * dir);
            ctx.moveTo(fromX, toY);
            ctx.lineTo(fromX + headlen*0.6, toY - headlen * dir);
            ctx.strokeStyle = color;
            ctx.lineWidth = 3;
            ctx.stroke();
        }

        function drawFrame() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            
            const isTh = document.body.classList.contains('lang-th');
            const topOffset = 20;
            
            ctx.fillStyle = params.eta > 1 ? (params.eta > 5 ? 'rgba(251, 191, 36, 0.3)' : 'rgba(147, 197, 253, 0.5)') : 'rgba(191, 219, 254, 0.4)';
            ctx.fillRect(40, 0, canvas.width - 80, canvas.height);

            ctx.fillStyle = '#64748b';
            ctx.font = 'bold 12px Inter';
            ctx.textAlign = 'right';
            
            let step = tankHeight_m > 10 ? 2 : 1;
            
            for(let i=0; i<=Math.ceil(tankHeight_m); i+=step) {
                const markY = topOffset + (i * pixelsPerMeter);
                if (markY > canvas.height - topOffset + 0.1) continue; 
                
                ctx.beginPath();
                ctx.moveTo(30, markY);
                ctx.lineTo(40, markY);
                ctx.strokeStyle = '#94a3b8';
                ctx.lineWidth = 2;
                ctx.stroke();
                ctx.fillText(i + 'm', 25, markY + 4);
            }
            
            // ปรับขนาดภาพลูกบอลให้ดูเล็กลงและสมส่วนกับท่อมากขึ้น
            const visualR = Math.max(5, params.r_m * 1000 * 0.8); 
            const cx = canvas.width / 2;
            ctx.textAlign = 'left';
            
            markers.forEach(m => {
                const my = topOffset + (m.y_m * pixelsPerMeter);
                
                ctx.beginPath();
                ctx.arc(cx, my, visualR, 0, Math.PI*2);
                ctx.fillStyle = 'rgba(100, 116, 139, 0.2)';
                ctx.fill();
                ctx.strokeStyle = 'rgba(100, 116, 139, 0.4)';
                ctx.lineWidth = 1;
                ctx.stroke();
                
                ctx.fillStyle = '#64748b'; 
                ctx.font = '10px Inter'; 
                ctx.fillText(`t = ${m.time.toFixed(1)}s`, cx + visualR + 10, my + 3);
                
                ctx.beginPath();
                ctx.moveTo(cx + visualR + 2, my);
                ctx.lineTo(cx + visualR + 8, my);
                ctx.strokeStyle = '#cbd5e1'; 
                ctx.stroke();
            });

            const cy = topOffset + (state.y_m * pixelsPerMeter);
            ctx.beginPath();
            ctx.arc(cx, cy, visualR, 0, Math.PI*2);
            ctx.fillStyle = params.rho_s === 7800 ? '#475569' : (params.rho_s === 2500 ? '#93c5fd' : '#b45309');
            ctx.fill();
            ctx.strokeStyle = '#1e293b';
            ctx.lineWidth = 2;
            ctx.stroke();

            const vol = (4/3) * Math.PI * Math.pow(params.r_m, 3);
            const W = vol * params.rho_s * g;
            const Fb = vol * params.rho_f * g;
            const Fd = 6 * Math.PI * params.eta * params.r_m * Math.abs(state.v);

            // ขยับลูกศรเวกเตอร์ตามขนาดของรัศมีวัตถุ (visualR)
            const arrowOffset = visualR + 4;

            drawArrow(cx, cy, W * forceScale, '#dc2626', false);
            drawArrow(cx - arrowOffset, cy, Fb * forceScale, '#3b82f6', true);
            if (Fd > 0) {
                const isDragUp = state.v >= 0;
                drawArrow(cx + arrowOffset, cy, Fd * forceScale, '#22c55e', isDragUp);
            }
            
            // แสดงเวลาและ Speed ของแอนิเมชันให้ผู้ใช้ทราบ
            ctx.textAlign = 'right';
            ctx.fillStyle = '#334155';
            ctx.font = 'bold 14px Inter';
            ctx.fillText(`${isTh ? 'เวลา' : 'Time'}: ${state.time.toFixed(2)}s`, canvas.width - 15, 25);
            
            if (Math.abs(simSpeedMultiplier - 1.0) > 0.05) {
                ctx.font = '12px Inter';
                ctx.fillStyle = '#64748b';
                ctx.fillText(`(Speed: ${simSpeedMultiplier.toFixed(1)}x)`, canvas.width - 15, 42);
            }
        }

        let lastTime = 0;
        let chartData = [];
        let lastChartTime = 0;
        let physicsAccumulator = 0;

        function startSim() {
            if(simRunning) return;
            
            if (state.y_m >= tankHeight_m - (params.r_m*2) || state.y_m <= 0) {
                previewPosition(); 
            }
            
            simRunning = true;
            lastTime = performance.now();
            chartData = [{ x: 0, y: state.v }]; 
            lastChartTime = 0;
            physicsAccumulator = 0;
            updateSim(); 
        }

        function resetSim() {
            simRunning = false;
            if (animationId) cancelAnimationFrame(animationId);
            previewPosition(); // เรียกให้วาดฉากเริ่มต้นใหม่
        }

        function updateSim() {
            if (!simRunning) return;

            const now = performance.now();
            // นำตัวคูณเวลาที่ประเมินได้จาก Preview มาใช้ปรับ Frame ให้เคลื่อนที่สมจริงทางความรู้สึก
            let frameTime = ((now - lastTime) / 1000) * simSpeedMultiplier;
            lastTime = now;

            if (frameTime > 0.5) frameTime = 0.5; 
            physicsAccumulator += frameTime;

            const FIXED_DT = 0.01; 
            let needsChartUpdate = false;

            while (physicsAccumulator >= FIXED_DT) {
                const vol = (4/3) * Math.PI * Math.pow(params.r_m, 3);
                const m = vol * params.rho_s;
                const W = m * g;
                const Fb = vol * params.rho_f * g;
                
                const Fd_mag = 6 * Math.PI * params.eta * params.r_m * Math.abs(state.v);
                const dir = state.v >= 0 ? 1 : -1; 
                
                const Fnet = W - Fb - (Fd_mag * dir);
                const a = Fnet / m;
                
                state.v += a * FIXED_DT;
                state.y_m += state.v * FIXED_DT;
                state.time += FIXED_DT;

                // ทิ้ง Marker ไว้ตามระยะเวลาที่กำหนดไว้
                if (state.time >= nextMarkerTime) {
                    markers.push({ y_m: state.y_m, time: nextMarkerTime });
                    nextMarkerTime += markerInterval;
                }

                // พลอตกราฟตามสัดส่วนเวลา เพื่อลดอาการแล็กจากการส่งข้อมูลมากเกินไป
                const chartDrawInterval = Math.max(0.02, simMaxTime / 200); 
                if (state.time - lastChartTime >= chartDrawInterval) {
                    chartData.push({ x: state.time, y: state.v });
                    lastChartTime = state.time;
                    needsChartUpdate = true;
                }

                physicsAccumulator -= FIXED_DT;

                if (state.y_m >= tankHeight_m && state.v > 0) {
                    state.y_m = tankHeight_m;
                    state.v = 0;
                    simRunning = false;
                    break; 
                } else if (state.y_m <= 0 && state.v < 0) {
                    state.y_m = 0;
                    state.v = 0;
                    simRunning = false;
                    break;
                }
            }

            // อัปเดตกราฟแบบไม่ขยับขอบเขตสเกล เพื่อความราบเรียบในการมอง
            if (needsChartUpdate && simRunning) {
                myChart.data.datasets[0].data = chartData;
                myChart.update();
            }

            drawFrame();
            
            if (simRunning) {
                animationId = requestAnimationFrame(updateSim);
            }
        }
    </script>
</body>
</html>
